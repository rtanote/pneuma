[Unit]
Description=Pneuma Air Quality API
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=rt
WorkingDirectory=/home/rt/dev/pneuma
EnvironmentFile=/home/rt/dev/pneuma/.env
ExecStart=/home/rt/dev/pneuma/.venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
