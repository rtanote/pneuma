# Sensor
SENSOR_PORT=COM3                    # Windows: COM3, Linux: /dev/ttyUSB0
INTERVAL_SEC=60
LOCATION_TAG=living_room
MOCK_SENSOR=false                   # true for development without sensor

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=pneuma-dev-token
INFLUX_ORG=home
INFLUX_BUCKET=air_quality

# FastAPI
API_PORT=8000

# BOCCO emo
BOCCO_API_KEY=your-bocco-personal-api-key
BOCCO_ROOM_ID=your-room-id
ALERT_COOLDOWN_MIN=30
ALERT_STATE_PATH=./alert_state.json

# LaMetric
LAMETRIC_DEVICE_IP=192.168.x.x
LAMETRIC_API_KEY=your-lametric-api-key
LAMETRIC_APP_ID=your-indicator-app-id
LAMETRIC_WIDGET_ID=your-widget-id
